  date DateTime

  checkIn  DateTime
  checkOut DateTime?

  status AttendanceStatus

  location String?

  remarks String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

