model Shipment {
  id                  String          @id @default(uuid())

  orderId             String          @unique
  order               Order           @relation(fields: [orderId], references: [id])

  trackingNumber      String?

  courier             String?

  status              OrderStatus

  shippedAt           DateTime?

  deliveredAt         DateTime?

  createdAt           DateTime        @default(now())
}
